PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/producto_backend
# Para PostgreSQL remoto (Cloud SQL, etc.): subir timeout y reciclar conexiones idle
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
JWT_SECRET=dev-secret-producto-backend-cambiar-en-produccion
JWT_EXPIRES_IN=1d

# Google Auth (ID Token — sin client secret)
GOOGLE_AUTH_ENABLED=true
GOOGLE_OAUTH_CLIENT_ID=
AUTH_EMAIL_PASSWORD_ENABLED=true
AUTH_DEV_EMAIL_LOGIN_ENABLED=true
BCRYPT_SALT_ROUNDS=10
C_DIGITAL_USERS_ENCRYPTION_KEY=dev-c-digital-users-key-change-in-production
SEED_ADMIN_PASSWORD=Admin123!
SEED_FABRICA_PASSWORD=Fabrica123!
SEED_PRODUCT_PASSWORD=Product123!
SEED_PLANEACION_PASSWORD=Planeacion123!
SEED_LMS_PASSWORD=Lms123!
# Opcional: una sola contraseña para todos los usuarios seed
# SEED_DEFAULT_PASSWORD=DevSeed123!

# Workflow institucional por asignatura (operational_state)
INSTITUTIONAL_WORKFLOW_ENABLED=true
INSTITUTIONAL_FLOW_MODE=full
PRODUCT_ACADEMIC_REVIEW_BUSINESS_DAYS=5

# Correo institucional — modo prueba (destinatarios lógicos @cun.edu.co → EMAIL_TEST_RECIPIENT)
# PRODUCT_REQUEST_CREATED: destinatario lógico fijo desarrollofabrica@cun.edu.co (fase actual).
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME="Operación Académica CUN"
EMAIL_FROM_ADDRESS=desarrollofabrica@cun.edu.co
EMAIL_TEST_MODE=true
EMAIL_TEST_RECIPIENT=
# Dominio permitido en modo real (EMAIL_TEST_MODE=false)
EMAIL_ALLOWED_DOMAIN=cun.edu.co
EMAIL_BLOCK_LOCAL_RECIPIENTS=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# SMTP técnico (relay temporal hasta SMTP institucional — no define destinatarios)

# URL pública del frontend (para enlaces CTA en correos)
APP_PUBLIC_URL=http://localhost:5173
# Opcional: URL absoluta del logo en correos. Si no se define, el logo va inline en el HTML (sin adjunto).
# EMAIL_BRAND_LOGO_URL=
